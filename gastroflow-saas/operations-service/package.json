{
  "name": "operations-service",
  "version": "0.0.1",
  "private": true,
  "license": "UNLICENSED",
  "scripts": {
    "postinstall": "npm run prisma:branch:generate",
    "prebuild": "npm run prisma:branch:generate",
    "build": "nest build",
    "prisma:branch:format": "prisma format --config prisma/branch/prisma.config.ts",
    "prisma:branch:validate": "prisma validate --config prisma/branch/prisma.config.ts",
    "prisma:branch:generate": "prisma generate --config prisma/branch/prisma.config.ts",
    "prisma:branch:migrate:principal": "tsx scripts/migrate-branch.ts principal dev",
    "prisma:branch:migrate:norte": "tsx scripts/migrate-branch.ts norte dev",
    "prisma:branch:deploy:principal": "tsx scripts/migrate-branch.ts principal deploy",
    "prisma:branch:deploy:norte": "tsx scripts/migrate-branch.ts norte deploy",
    "prisma:branch:seed:principal": "tsx prisma/branch/seed.ts principal",
    "prisma:branch:seed:norte": "tsx prisma/branch/seed.ts norte",
    "branches:migrate-all": "tsx scripts/migrate-all-branches.ts",
    "branches:status": "tsx scripts/branch-status.ts",
    "verify:branch-isolation": "tsx scripts/verify-branch-isolation.ts",
    "verify:dynamic-branches": "tsx scripts/verify-dynamic-branch-clients.ts",
    "wait:postgres": "tsx scripts/wait-for-postgres.ts",
    "format": "prettier --write \"src/**/*.ts\" \"test/**/*.ts\" \"scripts/**/*.ts\" \"prisma/**/*.ts\"",
    "start": "nest start",
    "start:dev": "nest start --watch",
    "start:debug": "nest start --debug --watch",
    "start:prod": "node dist/main",
    "lint": "eslint \"{src,apps,libs,test,scripts,prisma}/**/*.ts\" --fix",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:cov": "jest --coverage",
    "test:debug": "node --inspect-brk -r tsconfig-paths/register node_modules/.bin/jest --runInBand",
    "test:e2e": "jest --config ./test/jest-e2e.json",
    "test:integration": "node --experimental-vm-modules ./node_modules/jest/bin/jest.js --config ./test/jest-integration.json --runInBand",
    "provisioning:test": "jest provisioning --runInBand",
    "provisioning:test:integration": "npm run test:integration"
  },
  "dependencies": {
    "@nestjs/common": "^11.0.1",
    "@nestjs/config": "^4.0.4",
    "@nestjs/core": "^11.0.1",
    "@nestjs/microservices": "^11.1.28",
    "@nestjs/platform-express": "^11.0.1",
    "@prisma/adapter-pg": "^7.8.0",
    "@prisma/client": "^7.8.0",
    "dotenv": "^17.4.1",
    "pg": "^8.16.3",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.1"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3.2.0",
    "@eslint/js": "^9.18.0",
    "@nestjs/cli": "^11.0.0",
    "@nestjs/schematics": "^11.0.0",
    "@nestjs/testing": "^11.0.1",
    "@types/express": "^5.0.0",
    "@types/jest": "^30.0.0",
    "@types/node": "^24.0.0",
    "@types/pg": "^8.15.6",
    "@types/supertest": "^7.0.0",
    "eslint": "^9.18.0",
    "eslint-config-prettier": "^10.0.1",
    "eslint-plugin-prettier": "^5.2.2",
    "globals": "^17.0.0",
    "jest": "^30.0.0",
    "prettier": "^3.4.2",
    "prisma": "^7.8.0",
    "source-map-support": "^0.5.21",
    "supertest": "^7.0.0",
    "ts-jest": "^29.2.5",
    "ts-loader": "^9.5.2",
    "ts-node": "^10.9.2",
    "tsconfig-paths": "^4.2.0",
    "tsx": "^4.20.6",
    "typescript": "^5.7.3",
    "typescript-eslint": "^8.20.0"
  },
  "jest": {
    "moduleFileExtensions": ["js", "json", "ts"],
    "rootDir": "src",
    "testRegex": ".*\\.spec\\.ts$",
    "transform": {"^.+\\.(t|j)s$": "ts-jest"},
    "moduleNameMapper": {"^(\\.{1,2}/.*)\\.js$": "$1"},
    "collectCoverageFrom": ["**/*.(t|j)s"],
    "coverageDirectory": "../coverage",
    "testEnvironment": "node"
  },
  "overrides": {"@hono/node-server": "1.19.13"}
}

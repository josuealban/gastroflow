generator client {
  provider     = "prisma-client"
  output       = "../src/generated/operations-client"
  moduleFormat = "cjs"
}

datasource db {
  provider = "postgresql"
}

enum TableStatus {
  AVAILABLE
  OCCUPIED
  RESERVED
  OUT_OF_SERVICE
}

enum OrderStatus {
  OPEN
  IN_PREPARATION
  READY
  DELIVERED
  PAID
  CANCELLED
}

enum PaymentMethod {
  CASH
  CARD
  TRANSFER
}

enum PaymentStatus {
  PENDING
  COMPLETED
  FAILED
  REFUNDED
}

enum InvoiceStatus {
  ISSUED
  CANCELLED
}

enum InventoryItemType {
  INGREDIENT
  CONSUMABLE
  UTENSIL
}

enum InventoryUnit {
  UNIT
  GRAM
  KILOGRAM
  MILLILITER
  LITER
}

enum InventoryMovementType {
  PURCHASE_ENTRY
  MANUAL_ENTRY
  MANUAL_EXIT
  ADJUSTMENT
  WASTE
  DAMAGED
  LOST
  RETURN
}

enum PurchaseStatus {
  DRAFT
  ORDERED
  RECEIVED
  CANCELLED
}

model Category {
  id           String    @id @default(uuid()) @db.Uuid
  restaurantId String    @db.Uuid
  name         String
  description  String?
  isActive     Boolean   @default(true)
  createdAt    DateTime  @default(now()) @db.Timestamptz(3)
  updatedAt    DateTime  @updatedAt @db.Timestamptz(3)
  products     Product[]

  @@unique([restaurantId, name])
  @@unique([id, restaurantId])
  @@index([restaurantId, isActive])
}

model Product {
  id                    String        @id @default(uuid()) @db.Uuid
  restaurantId          String        @db.Uuid
  categoryId            String        @db.Uuid
  name                  String
  description           String?
  ingredientDescription String?
  price                 Decimal       @db.Decimal(12, 2)
  imageUrl              String?
  isAvailable           Boolean       @default(true)
  createdAt             DateTime      @default(now()) @db.Timestamptz(3)
  updatedAt             DateTime      @updatedAt @db.Timestamptz(3)
  category              Category      @relation(fields: [categoryId, restaurantId], references: [id, restaurantId], onDelete: Restrict)
  orderItems            OrderItem[]
  invoiceItems          InvoiceItem[]

  @@unique([restaurantId, name])
  @@unique([id, restaurantId])
  @@index([restaurantId, categoryId, isAvailable])
}

model RestaurantTable {
  id           String      @id @default(uuid()) @db.Uuid
  restaurantId String      @db.Uuid
  number       Int
  capacity     Int
  status       TableStatus @default(AVAILABLE)
  isActive     Boolean     @default(true)
  createdAt    DateTime    @default(now()) @db.Timestamptz(3)
  updatedAt    DateTime    @updatedAt @db.Timestamptz(3)
  orders       Order[]

  @@unique([restaurantId, number])
  @@unique([id, restaurantId])
  @@index([restaurantId, status, isActive])
}

model Order {
  id                 String           @id @default(uuid()) @db.Uuid
  restaurantId       String           @db.Uuid
  customerId         String?          @db.Uuid
  waiterId           String           @db.Uuid
  tableId            String?          @db.Uuid
  status             OrderStatus      @default(OPEN)
  subtotal           Decimal          @db.Decimal(12, 2)
  tax                Decimal          @db.Decimal(12, 2)
  total              Decimal          @db.Decimal(12, 2)
  notes              String?
  cancellationReason String?
  createdAt          DateTime         @default(now()) @db.Timestamptz(3)
  updatedAt          DateTime         @updatedAt @db.Timestamptz(3)
  table              RestaurantTable? @relation(fields: [tableId, restaurantId], references: [id, restaurantId], onDelete: Restrict)
  items              OrderItem[]
  payments           Payment[]
  invoice            Invoice?

  @@unique([id, restaurantId])
  @@index([restaurantId, status, createdAt])
  @@index([restaurantId, customerId])
  @@index([restaurantId, waiterId, createdAt])
  @@index([tableId, restaurantId])
}

model OrderItem {
  id           String   @id @default(uuid()) @db.Uuid
  restaurantId String   @db.Uuid
  orderId      String   @db.Uuid
  productId    String?  @db.Uuid
  productName  String
  quantity     Int
  unitPrice    Decimal  @db.Decimal(12, 2)
  subtotal     Decimal  @db.Decimal(12, 2)
  notes        String?
  createdAt    DateTime @default(now()) @db.Timestamptz(3)
  order        Order    @relation(fields: [orderId, restaurantId], references: [id, restaurantId], onDelete: Restrict)
  product      Product? @relation(fields: [productId, restaurantId], references: [id, restaurantId], onDelete: Restrict)

  @@index([restaurantId, orderId])
  @@index([productId, restaurantId])
}

model Payment {
  id           String        @id @default(uuid()) @db.Uuid
  restaurantId String        @db.Uuid
  orderId      String        @db.Uuid
  amount       Decimal       @db.Decimal(12, 2)
  method       PaymentMethod
  status       PaymentStatus @default(PENDING)
  reference    String?
  paidAt       DateTime      @db.Timestamptz(3)
  createdAt    DateTime      @default(now()) @db.Timestamptz(3)
  order        Order         @relation(fields: [orderId, restaurantId], references: [id, restaurantId], onDelete: Restrict)

  @@index([restaurantId, orderId, status])
  @@index([restaurantId, paidAt])
}

model TaxConfiguration {
  id            String    @id @default(uuid()) @db.Uuid
  restaurantId  String    @db.Uuid
  name          String
  rate          Decimal   @db.Decimal(7, 4)
  effectiveFrom DateTime  @db.Timestamptz(3)
  effectiveTo   DateTime? @db.Timestamptz(3)
  isActive      Boolean   @default(true)
  createdAt     DateTime  @default(now()) @db.Timestamptz(3)
  updatedAt     DateTime  @updatedAt @db.Timestamptz(3)

  @@index([restaurantId, isActive, effectiveFrom])
}

model InvoiceSequence {
  id            String   @id @default(uuid()) @db.Uuid
  restaurantId  String   @db.Uuid
  establishment String
  emissionPoint String
  currentNumber Int      @default(0)
  createdAt     DateTime @default(now()) @db.Timestamptz(3)
  updatedAt     DateTime @updatedAt @db.Timestamptz(3)

  @@unique([restaurantId, establishment, emissionPoint])
}

model Invoice {
  id                     String        @id @default(uuid()) @db.Uuid
  restaurantId           String        @db.Uuid
  orderId                String        @unique @db.Uuid
  customerId             String?       @db.Uuid
  createdByUserId        String        @db.Uuid
  invoiceNumber          String
  status                 InvoiceStatus @default(ISSUED)
  customerName           String
  customerIdentification String?
  customerEmail          String?
  subtotal               Decimal       @db.Decimal(12, 2)
  taxRate                Decimal       @db.Decimal(7, 4)
  taxAmount              Decimal       @db.Decimal(12, 2)
  total                  Decimal       @db.Decimal(12, 2)
  issuedAt               DateTime      @db.Timestamptz(3)
  cancelledAt            DateTime?     @db.Timestamptz(3)
  cancellationReason     String?
  createdAt              DateTime      @default(now()) @db.Timestamptz(3)
  updatedAt              DateTime      @updatedAt @db.Timestamptz(3)
  order                  Order         @relation(fields: [orderId, restaurantId], references: [id, restaurantId], onDelete: Restrict)
  items                  InvoiceItem[]

  @@unique([restaurantId, invoiceNumber])
  @@unique([orderId, restaurantId])
  @@unique([id, restaurantId])
  @@index([restaurantId, status, issuedAt])
  @@index([restaurantId, customerId])
}

model InvoiceItem {
  id           String   @id @default(uuid()) @db.Uuid
  restaurantId String   @db.Uuid
  invoiceId    String   @db.Uuid
  productId    String?  @db.Uuid
  productName  String
  quantity     Int
  unitPrice    Decimal  @db.Decimal(12, 2)
  subtotal     Decimal  @db.Decimal(12, 2)
  createdAt    DateTime @default(now()) @db.Timestamptz(3)
  invoice      Invoice  @relation(fields: [invoiceId, restaurantId], references: [id, restaurantId], onDelete: Restrict)
  product      Product? @relation(fields: [productId, restaurantId], references: [id, restaurantId], onDelete: Restrict)

  @@index([restaurantId, invoiceId])
  @@index([productId, restaurantId])
}

model InventoryItem {
  id                 String              @id @default(uuid()) @db.Uuid
  restaurantId       String              @db.Uuid
  name               String
  description        String?
  type               InventoryItemType
  unit               InventoryUnit
  currentStock       Decimal             @db.Decimal(14, 3)
  minimumStock       Decimal             @db.Decimal(14, 3)
  costPerUnit        Decimal             @db.Decimal(12, 4)
  damagedQuantity    Decimal             @default(0) @db.Decimal(14, 3)
  lostQuantity       Decimal             @default(0) @db.Decimal(14, 3)
  isActive           Boolean             @default(true)
  createdAt          DateTime            @default(now()) @db.Timestamptz(3)
  updatedAt          DateTime            @updatedAt @db.Timestamptz(3)
  purchaseItems      PurchaseItem[]
  inventoryMovements InventoryMovement[]

  @@unique([restaurantId, name])
  @@unique([id, restaurantId])
  @@index([restaurantId, type, isActive])
  @@index([restaurantId, currentStock])
}

model Supplier {
  id           String     @id @default(uuid()) @db.Uuid
  restaurantId String     @db.Uuid
  name         String
  taxId        String?
  phone        String?
  email        String?
  address      String?
  isActive     Boolean    @default(true)
  createdAt    DateTime   @default(now()) @db.Timestamptz(3)
  updatedAt    DateTime   @updatedAt @db.Timestamptz(3)
  purchases    Purchase[]

  @@unique([id, restaurantId])
  @@index([restaurantId, name])
  @@index([restaurantId, taxId])
  @@index([restaurantId, isActive])
}

model Purchase {
  id              String         @id @default(uuid()) @db.Uuid
  restaurantId    String         @db.Uuid
  supplierId      String         @db.Uuid
  createdByUserId String         @db.Uuid
  invoiceNumber   String?
  status          PurchaseStatus @default(DRAFT)
  subtotal        Decimal        @db.Decimal(12, 2)
  tax             Decimal        @db.Decimal(12, 2)
  total           Decimal        @db.Decimal(12, 2)
  receivedAt      DateTime?      @db.Timestamptz(3)
  cancelledAt     DateTime?      @db.Timestamptz(3)
  createdAt       DateTime       @default(now()) @db.Timestamptz(3)
  updatedAt       DateTime       @updatedAt @db.Timestamptz(3)
  supplier        Supplier       @relation(fields: [supplierId, restaurantId], references: [id, restaurantId], onDelete: Restrict)
  items           PurchaseItem[]

  @@unique([id, restaurantId])
  @@index([restaurantId, status, createdAt])
  @@index([supplierId, restaurantId])
  @@index([restaurantId, createdByUserId])
}

model PurchaseItem {
  id              String        @id @default(uuid()) @db.Uuid
  restaurantId    String        @db.Uuid
  purchaseId      String        @db.Uuid
  inventoryItemId String        @db.Uuid
  quantity        Decimal       @db.Decimal(14, 3)
  unitCost        Decimal       @db.Decimal(12, 4)
  subtotal        Decimal       @db.Decimal(12, 2)
  purchase        Purchase      @relation(fields: [purchaseId, restaurantId], references: [id, restaurantId], onDelete: Restrict)
  inventoryItem   InventoryItem @relation(fields: [inventoryItemId, restaurantId], references: [id, restaurantId], onDelete: Restrict)

  @@index([purchaseId, restaurantId])
  @@index([inventoryItemId, restaurantId])
}

model InventoryMovement {
  id              String                @id @default(uuid()) @db.Uuid
  restaurantId    String                @db.Uuid
  inventoryItemId String                @db.Uuid
  createdByUserId String?               @db.Uuid
  type            InventoryMovementType
  quantity        Decimal               @db.Decimal(14, 3)
  previousStock   Decimal               @db.Decimal(14, 3)
  newStock        Decimal               @db.Decimal(14, 3)
  reason          String?
  referenceType   String?
  referenceId     String?
  createdAt       DateTime              @default(now()) @db.Timestamptz(3)
  inventoryItem   InventoryItem         @relation(fields: [inventoryItemId, restaurantId], references: [id, restaurantId], onDelete: Restrict)

  @@index([restaurantId, inventoryItemId, createdAt])
  @@index([restaurantId, createdByUserId])
  @@index([restaurantId, type, createdAt])
  @@index([restaurantId, referenceType, referenceId])
}

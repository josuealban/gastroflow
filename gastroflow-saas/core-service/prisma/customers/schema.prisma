generator client {
  provider     = "prisma-client"
  output       = "../../src/generated/customers-client"
  moduleFormat = "cjs"
}

datasource db {
  provider = "postgresql"
}

enum ReservationStatus {
  PENDING
  CONFIRMED
  COMPLETED
  CANCELLED
}

model Customer {
  id             String               @id @default(uuid()) @db.Uuid
  restaurantId   String               @db.Uuid
  name           String
  identification String?
  phone          String?
  email          String?
  address        String?
  notes          String?
  isActive       Boolean              @default(true)
  createdAt      DateTime             @default(now()) @db.Timestamptz(3)
  updatedAt      DateTime             @updatedAt @db.Timestamptz(3)
  reservations   Reservation[]
  customerNotes  CustomerNote[]
  preferences    CustomerPreference[]

  @@unique([restaurantId, identification])
  @@unique([id, restaurantId])
  @@index([restaurantId, isActive])
  @@index([restaurantId, phone])
  @@index([restaurantId, email])
}

model Reservation {
  id              String            @id @default(uuid()) @db.Uuid
  restaurantId    String            @db.Uuid
  customerId      String            @db.Uuid
  tableId         String?           @db.Uuid
  reservationDate DateTime          @db.Timestamptz(3)
  numberOfGuests  Int
  status          ReservationStatus @default(PENDING)
  notes           String?
  createdAt       DateTime          @default(now()) @db.Timestamptz(3)
  updatedAt       DateTime          @updatedAt @db.Timestamptz(3)
  customer        Customer          @relation(fields: [customerId, restaurantId], references: [id, restaurantId], onDelete: Restrict)

  @@index([restaurantId, reservationDate])
  @@index([restaurantId, status, reservationDate])
  @@index([customerId, restaurantId])
  @@index([tableId])
}

model CustomerNote {
  id              String   @id @default(uuid()) @db.Uuid
  restaurantId    String   @db.Uuid
  customerId      String   @db.Uuid
  content         String
  createdByUserId String?  @db.Uuid
  createdAt       DateTime @default(now()) @db.Timestamptz(3)
  customer        Customer @relation(fields: [customerId, restaurantId], references: [id, restaurantId], onDelete: Restrict)

  @@index([restaurantId, customerId])
  @@index([createdByUserId])
}

model CustomerPreference {
  id           String   @id @default(uuid()) @db.Uuid
  restaurantId String   @db.Uuid
  customerId   String   @db.Uuid
  description  String
  createdAt    DateTime @default(now()) @db.Timestamptz(3)
  updatedAt    DateTime @updatedAt @db.Timestamptz(3)
  customer     Customer @relation(fields: [customerId, restaurantId], references: [id, restaurantId], onDelete: Restrict)

  @@index([restaurantId, customerId])
}

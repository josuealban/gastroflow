generator client {
  provider     = "prisma-client"
  output       = "../../src/generated/control-client"
  moduleFormat = "cjs"
}

datasource db {
  provider = "postgresql"
}

enum SubscriptionStatus {
  TRIAL
  ACTIVE
  EXPIRED
  SUSPENDED
}

enum OutboxStatus {
  PENDING
  PROCESSING
  PROCESSED
  FAILED
}

model Company {
  id           String        @id @default(uuid()) @db.Uuid
  name         String
  legalName    String?
  taxId        String?
  email        String
  phone        String?
  isActive     Boolean       @default(true)
  createdAt    DateTime      @default(now()) @db.Timestamptz(3)
  updatedAt    DateTime      @updatedAt @db.Timestamptz(3)
  branches     Branch[]
  subscription Subscription?

  @@index([isActive])
  @@index([email])
}

model Branch {
  id                        String   @id @default(uuid()) @db.Uuid
  companyId                 String   @db.Uuid
  name                      String
  code                      String   @unique
  address                   String?
  phone                     String?
  databaseName              String   @unique
  databaseHost              String
  databasePort              Int
  databaseUser              String
  encryptedDatabasePassword String
  isActive                  Boolean  @default(true)
  createdAt                 DateTime @default(now()) @db.Timestamptz(3)
  updatedAt                 DateTime @updatedAt @db.Timestamptz(3)
  company                   Company  @relation(fields: [companyId], references: [id], onDelete: Restrict)

  @@index([companyId, isActive])
  @@index([code, isActive])
}

model Plan {
  id                   String         @id @default(uuid()) @db.Uuid
  name                 String         @unique
  description          String?
  price                Decimal        @db.Decimal(12, 2)
  maxBranches          Int
  maxUsersPerBranch    Int
  maxTablesPerBranch   Int
  maxProductsPerBranch Int
  isActive             Boolean        @default(true)
  createdAt            DateTime       @default(now()) @db.Timestamptz(3)
  updatedAt            DateTime       @updatedAt @db.Timestamptz(3)
  subscriptions        Subscription[]

  @@index([isActive])
}

model Subscription {
  id        String             @id @default(uuid()) @db.Uuid
  companyId String             @unique @db.Uuid
  planId    String             @db.Uuid
  status    SubscriptionStatus
  startDate DateTime           @db.Timestamptz(3)
  endDate   DateTime           @db.Timestamptz(3)
  createdAt DateTime           @default(now()) @db.Timestamptz(3)
  updatedAt DateTime           @updatedAt @db.Timestamptz(3)
  company   Company            @relation(fields: [companyId], references: [id], onDelete: Restrict)
  plan      Plan               @relation(fields: [planId], references: [id], onDelete: Restrict)

  @@index([planId])
  @@index([status, endDate])
}

model PlatformAdmin {
  id           String   @id @default(uuid()) @db.Uuid
  name         String
  email        String   @unique
  passwordHash String
  isActive     Boolean  @default(true)
  createdAt    DateTime @default(now()) @db.Timestamptz(3)
  updatedAt    DateTime @updatedAt @db.Timestamptz(3)

  @@index([isActive])
}

model GlobalOutboxEvent {
  id            String       @id @default(uuid()) @db.Uuid
  eventType     String
  aggregateType String
  aggregateId   String?
  payload       Json
  status        OutboxStatus @default(PENDING)
  attempts      Int          @default(0)
  lastError     String?
  createdAt     DateTime     @default(now()) @db.Timestamptz(3)
  processedAt   DateTime?    @db.Timestamptz(3)

  @@index([status, createdAt])
  @@index([aggregateType, aggregateId])
}

generator client {
  provider     = "prisma-client"
  output       = "../../src/generated/branch-client"
  moduleFormat = "cjs"
}

datasource db {
  provider = "postgresql"
}

enum TableStatus {
  AVAILABLE
  OCCUPIED
  RESERVED
  OUT_OF_SERVICE
}

enum ReservationStatus {
  PENDING
  CONFIRMED
  COMPLETED
  CANCELLED
}

enum OrderStatus {
  OPEN
  IN_PREPARATION
  READY
  DELIVERED
  PAID
  CANCELLED
}

enum PaymentMethod {
  CASH
  CARD
  TRANSFER
}

enum PaymentStatus {
  PENDING
  COMPLETED
  FAILED
  REFUNDED
}

enum InventoryUnit {
  UNIT
  GRAM
  KILOGRAM
  MILLILITER
  LITER
}

enum InventoryMovementType {
  PURCHASE_ENTRY
  SALE_CONSUMPTION
  MANUAL_ENTRY
  MANUAL_EXIT
  ADJUSTMENT
  WASTE
  RETURN
}

enum PurchaseStatus {
  DRAFT
  ORDERED
  RECEIVED
  CANCELLED
}

enum OutboxStatus {
  PENDING
  PROCESSING
  PROCESSED
  FAILED
}

model User {
  id                 String              @id @default(uuid()) @db.Uuid
  name               String
  email              String              @unique
  passwordHash       String
  isActive           Boolean             @default(true)
  createdAt          DateTime            @default(now()) @db.Timestamptz(3)
  updatedAt          DateTime            @updatedAt @db.Timestamptz(3)
  userRoles          UserRole[]
  refreshTokens      RefreshToken[]
  ordersAsWaiter     Order[]
  purchases          Purchase[]
  inventoryMovements InventoryMovement[]

  @@index([isActive])
}

model Role {
  id              String           @id @default(uuid()) @db.Uuid
  name            String           @unique
  description     String?
  isActive        Boolean          @default(true)
  createdAt       DateTime         @default(now()) @db.Timestamptz(3)
  updatedAt       DateTime         @updatedAt @db.Timestamptz(3)
  userRoles       UserRole[]
  rolePermissions RolePermission[]

  @@index([isActive])
}

model Permission {
  id              String           @id @default(uuid()) @db.Uuid
  name            String           @unique
  description     String?
  createdAt       DateTime         @default(now()) @db.Timestamptz(3)
  updatedAt       DateTime         @updatedAt @db.Timestamptz(3)
  rolePermissions RolePermission[]
}

model UserRole {
  userId     String   @db.Uuid
  roleId     String   @db.Uuid
  assignedAt DateTime @default(now()) @db.Timestamptz(3)
  user       User     @relation(fields: [userId], references: [id], onDelete: Restrict)
  role       Role     @relation(fields: [roleId], references: [id], onDelete: Restrict)

  @@id([userId, roleId])
  @@index([roleId])
}

model RolePermission {
  roleId       String     @db.Uuid
  permissionId String     @db.Uuid
  assignedAt   DateTime   @default(now()) @db.Timestamptz(3)
  role         Role       @relation(fields: [roleId], references: [id], onDelete: Restrict)
  permission   Permission @relation(fields: [permissionId], references: [id], onDelete: Restrict)

  @@id([roleId, permissionId])
  @@index([permissionId])
}

model RefreshToken {
  id        String    @id @default(uuid()) @db.Uuid
  userId    String    @db.Uuid
  tokenHash String
  expiresAt DateTime  @db.Timestamptz(3)
  revokedAt DateTime? @db.Timestamptz(3)
  createdAt DateTime  @default(now()) @db.Timestamptz(3)
  user      User      @relation(fields: [userId], references: [id], onDelete: Restrict)

  @@index([userId, expiresAt])
  @@index([revokedAt])
}

model Category {
  id          String    @id @default(uuid()) @db.Uuid
  name        String    @unique
  description String?
  isActive    Boolean   @default(true)
  createdAt   DateTime  @default(now()) @db.Timestamptz(3)
  updatedAt   DateTime  @updatedAt @db.Timestamptz(3)
  products    Product[]

  @@index([isActive])
}

model Product {
  id          String      @id @default(uuid()) @db.Uuid
  categoryId  String      @db.Uuid
  name        String
  description String?
  price       Decimal     @db.Decimal(12, 2)
  imageUrl    String?
  isAvailable Boolean     @default(true)
  createdAt   DateTime    @default(now()) @db.Timestamptz(3)
  updatedAt   DateTime    @updatedAt @db.Timestamptz(3)
  category    Category    @relation(fields: [categoryId], references: [id], onDelete: Restrict)
  orderItems  OrderItem[]
  recipe      Recipe?

  @@index([categoryId, isAvailable])
  @@index([name])
}

model RestaurantTable {
  id           String        @id @default(uuid()) @db.Uuid
  number       Int           @unique
  capacity     Int
  status       TableStatus   @default(AVAILABLE)
  isActive     Boolean       @default(true)
  createdAt    DateTime      @default(now()) @db.Timestamptz(3)
  updatedAt    DateTime      @updatedAt @db.Timestamptz(3)
  reservations Reservation[]
  orders       Order[]

  @@index([status, isActive])
}

model Customer {
  id             String        @id @default(uuid()) @db.Uuid
  name           String
  identification String?
  phone          String?
  email          String?
  notes          String?
  isActive       Boolean       @default(true)
  createdAt      DateTime      @default(now()) @db.Timestamptz(3)
  updatedAt      DateTime      @updatedAt @db.Timestamptz(3)
  reservations   Reservation[]
  orders         Order[]

  @@index([identification])
  @@index([phone])
  @@index([email])
  @@index([isActive])
}

model Reservation {
  id              String            @id @default(uuid()) @db.Uuid
  customerId      String            @db.Uuid
  tableId         String?           @db.Uuid
  reservationDate DateTime          @db.Timestamptz(3)
  numberOfGuests  Int
  status          ReservationStatus @default(PENDING)
  notes           String?
  createdAt       DateTime          @default(now()) @db.Timestamptz(3)
  updatedAt       DateTime          @updatedAt @db.Timestamptz(3)
  customer        Customer          @relation(fields: [customerId], references: [id], onDelete: Restrict)
  table           RestaurantTable?  @relation(fields: [tableId], references: [id], onDelete: Restrict)

  @@index([customerId])
  @@index([tableId, reservationDate])
  @@index([status, reservationDate])
}

model Order {
  id                  String           @id @default(uuid()) @db.Uuid
  tableId             String?          @db.Uuid
  customerId          String?          @db.Uuid
  waiterId            String           @db.Uuid
  status              OrderStatus      @default(OPEN)
  subtotal            Decimal          @db.Decimal(12, 2)
  tax                 Decimal          @db.Decimal(12, 2)
  total               Decimal          @db.Decimal(12, 2)
  cancellationReason  String?
  inventoryDeductedAt DateTime?        @db.Timestamptz(3)
  createdAt           DateTime         @default(now()) @db.Timestamptz(3)
  updatedAt           DateTime         @updatedAt @db.Timestamptz(3)
  table               RestaurantTable? @relation(fields: [tableId], references: [id], onDelete: Restrict)
  customer            Customer?        @relation(fields: [customerId], references: [id], onDelete: Restrict)
  waiter              User             @relation(fields: [waiterId], references: [id], onDelete: Restrict)
  items               OrderItem[]
  payments            Payment[]

  @@index([tableId])
  @@index([customerId])
  @@index([waiterId, createdAt])
  @@index([status, createdAt])
}

model OrderItem {
  id        String   @id @default(uuid()) @db.Uuid
  orderId   String   @db.Uuid
  productId String   @db.Uuid
  quantity  Int
  unitPrice Decimal  @db.Decimal(12, 2)
  subtotal  Decimal  @db.Decimal(12, 2)
  notes     String?
  createdAt DateTime @default(now()) @db.Timestamptz(3)
  order     Order    @relation(fields: [orderId], references: [id], onDelete: Restrict)
  product   Product  @relation(fields: [productId], references: [id], onDelete: Restrict)

  @@index([orderId])
  @@index([productId])
}

model Payment {
  id        String        @id @default(uuid()) @db.Uuid
  orderId   String        @db.Uuid
  amount    Decimal       @db.Decimal(12, 2)
  method    PaymentMethod
  status    PaymentStatus @default(PENDING)
  reference String?
  paidAt    DateTime      @db.Timestamptz(3)
  createdAt DateTime      @default(now()) @db.Timestamptz(3)
  order     Order         @relation(fields: [orderId], references: [id], onDelete: Restrict)

  @@index([orderId, status])
  @@index([paidAt])
}

model InventoryItem {
  id                 String              @id @default(uuid()) @db.Uuid
  name               String              @unique
  description        String?
  unit               InventoryUnit
  currentStock       Decimal             @db.Decimal(14, 3)
  minimumStock       Decimal             @db.Decimal(14, 3)
  costPerUnit        Decimal             @db.Decimal(12, 4)
  isActive           Boolean             @default(true)
  createdAt          DateTime            @default(now()) @db.Timestamptz(3)
  updatedAt          DateTime            @updatedAt @db.Timestamptz(3)
  purchaseItems      PurchaseItem[]
  inventoryMovements InventoryMovement[]
  recipeItems        RecipeItem[]

  @@index([isActive])
  @@index([currentStock])
}

model Supplier {
  id        String     @id @default(uuid()) @db.Uuid
  name      String
  taxId     String?
  phone     String?
  email     String?
  address   String?
  isActive  Boolean    @default(true)
  createdAt DateTime   @default(now()) @db.Timestamptz(3)
  updatedAt DateTime   @updatedAt @db.Timestamptz(3)
  purchases Purchase[]

  @@index([taxId])
  @@index([isActive])
}

model Purchase {
  id            String         @id @default(uuid()) @db.Uuid
  supplierId    String         @db.Uuid
  userId        String         @db.Uuid
  invoiceNumber String?
  status        PurchaseStatus @default(DRAFT)
  subtotal      Decimal        @db.Decimal(12, 2)
  tax           Decimal        @db.Decimal(12, 2)
  total         Decimal        @db.Decimal(12, 2)
  receivedAt    DateTime?      @db.Timestamptz(3)
  cancelledAt   DateTime?      @db.Timestamptz(3)
  createdAt     DateTime       @default(now()) @db.Timestamptz(3)
  updatedAt     DateTime       @updatedAt @db.Timestamptz(3)
  supplier      Supplier       @relation(fields: [supplierId], references: [id], onDelete: Restrict)
  user          User           @relation(fields: [userId], references: [id], onDelete: Restrict)
  items         PurchaseItem[]

  @@index([supplierId])
  @@index([userId])
  @@index([status, createdAt])
}

model PurchaseItem {
  id              String        @id @default(uuid()) @db.Uuid
  purchaseId      String        @db.Uuid
  inventoryItemId String        @db.Uuid
  quantity        Decimal       @db.Decimal(14, 3)
  unitCost        Decimal       @db.Decimal(12, 4)
  subtotal        Decimal       @db.Decimal(12, 2)
  purchase        Purchase      @relation(fields: [purchaseId], references: [id], onDelete: Restrict)
  inventoryItem   InventoryItem @relation(fields: [inventoryItemId], references: [id], onDelete: Restrict)

  @@index([purchaseId])
  @@index([inventoryItemId])
}

model InventoryMovement {
  id              String                @id @default(uuid()) @db.Uuid
  inventoryItemId String                @db.Uuid
  userId          String?               @db.Uuid
  type            InventoryMovementType
  quantity        Decimal               @db.Decimal(14, 3)
  previousStock   Decimal               @db.Decimal(14, 3)
  newStock        Decimal               @db.Decimal(14, 3)
  reason          String?
  referenceType   String?
  referenceId     String?
  createdAt       DateTime              @default(now()) @db.Timestamptz(3)
  inventoryItem   InventoryItem         @relation(fields: [inventoryItemId], references: [id], onDelete: Restrict)
  user            User?                 @relation(fields: [userId], references: [id], onDelete: Restrict)

  @@index([inventoryItemId, createdAt])
  @@index([userId])
  @@index([type, createdAt])
  @@index([referenceType, referenceId])
}

model Recipe {
  id        String       @id @default(uuid()) @db.Uuid
  productId String       @unique @db.Uuid
  name      String
  isActive  Boolean      @default(true)
  createdAt DateTime     @default(now()) @db.Timestamptz(3)
  updatedAt DateTime     @updatedAt @db.Timestamptz(3)
  product   Product      @relation(fields: [productId], references: [id], onDelete: Restrict)
  items     RecipeItem[]

  @@index([isActive])
}

model RecipeItem {
  id               String        @id @default(uuid()) @db.Uuid
  recipeId         String        @db.Uuid
  inventoryItemId  String        @db.Uuid
  quantityRequired Decimal       @db.Decimal(14, 3)
  recipe           Recipe        @relation(fields: [recipeId], references: [id], onDelete: Restrict)
  inventoryItem    InventoryItem @relation(fields: [inventoryItemId], references: [id], onDelete: Restrict)

  @@unique([recipeId, inventoryItemId])
  @@index([inventoryItemId])
}

model OutboxEvent {
  id            String       @id @default(uuid()) @db.Uuid
  eventType     String
  aggregateType String
  aggregateId   String?
  payload       Json
  status        OutboxStatus @default(PENDING)
  attempts      Int          @default(0)
  lastError     String?
  createdAt     DateTime     @default(now()) @db.Timestamptz(3)
  processedAt   DateTime?    @db.Timestamptz(3)

  @@index([status, createdAt])
  @@index([aggregateType, aggregateId])
}

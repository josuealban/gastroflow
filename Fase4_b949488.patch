+      {branch.status === 'INACTIVE' && can('branches.deactivate') && <button onClick={() => void apiClient.patch(`/branches/${branch.id}/status`, { status: 'ACTIVE' }).then(load)}>Activar</button>}
+    </article>)}</div>
+  </section>;
